# Application
NODE_ENV=production
PORT=3000
AUTH_SALT_ROUNDS=10

# Database (PostgreSQL) - Docker service name
DB_HOST=db
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD
DB_NAME=url_shortener

# Redis - Docker service name
REDIS_URL=redis://127.0.0.1:6379
REDIS_PORT=6379

# Security (JWT) - GENERATE NEW SECRETS WITH: openssl rand -hex 32
JWT_ACCESS_SECRET=CHANGE_ME_GENERATE_WITH_OPENSSL_RAND_HEX_32
JWT_REFRESH_SECRET=CHANGE_ME_GENERATE_WITH_OPENSSL_RAND_HEX_32

# OTP
OTP_TTL_SECONDS=600
OTP_MAX_ATTEMPTS=5

# Mailer (SMTP)
# Dev (Mailtrap sandbox) example:
# MAIL_HOST=sandbox.smtp.mailtrap.io
# MAIL_PORT=2525
# MAIL_SECURE=false
# MAIL_USER=your_mailtrap_username
# MAIL_PASS=your_mailtrap_password
# MAIL_FROM=dev@example.com
# Prod (Resend SMTP) example:
# MAIL_HOST=smtp.resend.com
# MAIL_PORT=465
# MAIL_SECURE=true
# MAIL_USER=resend
# MAIL_PASS=your_resend_api_key
# MAIL_FROM=your_verified_sender@example.com
MAIL_HOST=CHANGE_ME_SMTP_HOST
MAIL_PORT=587
MAIL_SECURE=false
MAIL_USER=CHANGE_ME_SMTP_USER
MAIL_PASS=CHANGE_ME_SMTP_PASS
MAIL_FROM=CHANGE_ME_FROM_EMAIL

# Rate Limiting
MAX_URLS_PER_HOUR=50

# Database Connection Pool
DB_POOL_MIN=5
DB_POOL_MAX=20
DB_POOL_ACQUIRE_TIMEOUT=5000
DB_POOL_IDLE_TIMEOUT=30000

# Google Web Risk API (optional — URLs get safety_status='unknown' if unset)
GOOGLE_WEB_RISK_API_KEY=your_google_web_risk_api_key_here
