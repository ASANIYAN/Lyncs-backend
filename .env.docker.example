# Application
NODE_ENV=production
PORT=3000
AUTH_SALT_ROUNDS=10

# Database (PostgreSQL) - Docker service name
DB_HOST=db
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD
DB_NAME=url_shortener

# Redis - Docker service name
REDIS_URL=redis://127.0.0.1:6379
REDIS_PORT=6379

# Security (JWT) - GENERATE NEW SECRETS WITH: openssl rand -hex 32
JWT_ACCESS_SECRET=CHANGE_ME_GENERATE_WITH_OPENSSL_RAND_HEX_32
JWT_REFRESH_SECRET=CHANGE_ME_GENERATE_WITH_OPENSSL_RAND_HEX_32

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# Database Connection Pool
DB_POOL_MIN=5
DB_POOL_MAX=20
DB_POOL_ACQUIRE_TIMEOUT=5000
DB_POOL_IDLE_TIMEOUT=30000

# Google Web Risk API (optional — URLs get safety_status='unknown' if unset)
GOOGLE_WEB_RISK_API_KEY=your_google_web_risk_api_key_here
